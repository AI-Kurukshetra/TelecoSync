# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# Optional fallback for older local setups; the app prefers NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server only
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
SUPABASE_DOCUMENTS_BUCKET=documents

# Fault escalation
FAULT_ONCALL_SMS=+10000000000
FAULT_ONCALL_EMAIL=noc@example.com

# Integration security
INTERNAL_API_SECRET=shared_secret_for_internal_event_calls

# Revenue assurance
REVENUE_LEAKAGE_ALERT_THRESHOLD_PCT=0.5

# Analytics
VERCEL_ANALYTICS_P95_MS=0
# Optional remote source for production p95 metric collection
VERCEL_ANALYTICS_P95_ENDPOINT=https://example.com/vercel/p95
VERCEL_ANALYTICS_TOKEN=your_vercel_analytics_token
